# ============================================================
# .env.example — Template konfigurasi environment
# ============================================================
# Salin file ini menjadi .env lalu isi nilainya:
#   cp .env.example .env
# ============================================================

# --- OLLAMA ---
# URL dimana Ollama berjalan (default: localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Model chat yang dipakai. Pilih salah satu yang sudah di-pull:
#   ollama pull qwen2.5:7b
#   ollama pull gemma2:9b
#   ollama pull llama3.2:3b
OLLAMA_CHAT_MODEL=qwen2.5:7b

# Model embedding (wajib: nomic-embed-text)
#   ollama pull nomic-embed-text
OLLAMA_EMBED_MODEL=nomic-embed-text

# Suhu generasi (0.0 = deterministik, 1.0 = kreatif)
OLLAMA_TEMPERATURE=0.3

# --- LANGSMITH (opsional tapi direkomendasikan untuk UAS) ---
# Daftar gratis di: https://smith.langchain.com
# Aktifkan tracing dengan mengubah nilai ke "true"
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_api_key_here
LANGCHAIN_PROJECT=ai-pencari-resep-masakan

# --- PATH (opsional, ada default otomatis) ---
# DATA_PATH=data/resep_masakan.csv
# VECTORSTORE_DIR=vectorstore
# RETRIEVER_TOP_K=3
